# ============================================================================
# AI Disaster Response - Environment Variables
# ============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!

# ============================================================================
# LLM Provider Configuration
# ============================================================================

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=4000

# Anthropic Configuration
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-sonnet-20240229
ANTHROPIC_MAX_TOKENS=4000

# Default LLM provider (openai or anthropic)
DEFAULT_LLM_PROVIDER=openai

# ============================================================================
# Feature Flags - Provider Enable/Disable
# ============================================================================

# Enable/disable signal providers
ENABLE_TEXT_PROVIDER=true
ENABLE_VISION_PROVIDER=true
ENABLE_QUANT_PROVIDER=true

# ============================================================================
# Feature Flags - Pipeline Stages
# ============================================================================

# Enable/disable pipeline stages
ENABLE_EXTRACTION=true
ENABLE_FUSION=true
ENABLE_SCORING=true
ENABLE_ALERTS=true
ENABLE_VISUALIZATION=true

# Extraction rollout flag
ENABLE_REAL_TEXT_EXTRACTION=false
ENABLE_REAL_VISION_EXTRACTION=false
ENABLE_REAL_QUANT_EXTRACTION=false

# ============================================================================
# Feature Flags - Experimental Features
# ============================================================================

# Caching (requires Redis)
ENABLE_CACHING=false

# Rate limiting (requires Redis)
ENABLE_RATE_LIMITING=false

# Metrics collection (OpenTelemetry)
ENABLE_METRICS=false

# ============================================================================
# Database Configuration
# ============================================================================

# PostgreSQL (production)
DATABASE_URL=postgresql://user:password@localhost:5432/disaster_response

# SQLite (development)
# DATABASE_URL=sqlite:///disaster.db

# Connection pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ============================================================================
# Cache Configuration (Redis)
# ============================================================================

REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=3600

# ============================================================================
# Application Settings
# ============================================================================

# Debug mode (verbose logging, stack traces)
DEBUG=false

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log format (json or text)
LOG_FORMAT=json

# Server configuration
PORT=8000
HOST=0.0.0.0
WORKERS=4

# CORS configuration
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================================================
# External API Keys
# ============================================================================

# Weather API (NWS does not require an API key)
WEATHER_API_KEY=
WEATHER_API_URL=https://api.weather.gov

# Real-source weather/facility ingestion toggles (Tampa Bay MVP)
USE_REAL_WEATHER_PROVIDER=true
USE_REAL_FACILITY_PROVIDER=true
REAL_PROVIDER_FALLBACK_TO_SEED=true

# NWS (no API key required, but User-Agent should include app id + contact)
NWS_USER_AGENT=ai-disaster-response/1.0 (you@example.com)
NWS_TIMEOUT_SECONDS=8.0

# OSM Overpass (no API key required)
OSM_OVERPASS_URL=https://overpass-api.de/api/interpreter
OSM_TIMEOUT_SECONDS=12.0

# Maps API (e.g., Google Maps, Mapbox)
MAPS_API_KEY=your-maps-api-key
MAPS_API_URL=https://maps.googleapis.com/maps/api

# Emergency services API
EMERGENCY_API_KEY=your-emergency-api-key

# ============================================================================
# Security Configuration
# ============================================================================

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-here-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Session secret
SESSION_SECRET=your-session-secret-here-min-32-chars

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ============================================================================
# Processing Configuration
# ============================================================================

# Stage timeouts (seconds)
EXTRACTION_TIMEOUT_SECONDS=30
FUSION_TIMEOUT_SECONDS=15
SCORING_TIMEOUT_SECONDS=10
ALERT_TIMEOUT_SECONDS=5

# Confidence thresholds
MIN_CONFIDENCE_THRESHOLD=0.5
HIGH_CONFIDENCE_THRESHOLD=0.8

# Batch processing limits
MAX_SIGNALS_PER_REQUEST=100
MAX_EVENTS_PER_BATCH=50

# ============================================================================
# Development Settings
# ============================================================================

# For local development, you can use these simplified settings:
# DEBUG=true
# LOG_LEVEL=DEBUG
# LOG_FORMAT=text
# DATABASE_URL=sqlite:///disaster.db
# ENABLE_TEXT_PROVIDER=true
# ENABLE_VISION_PROVIDER=false
# ENABLE_QUANT_PROVIDER=false
# ENABLE_CACHING=false
# ENABLE_RATE_LIMITING=false
